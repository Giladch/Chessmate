<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chessmate</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        /* Background */
        body {
            background: linear-gradient(135deg, #1e1e2f, #252542);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            color: white;
            font-family: 'Poppins', sans-serif;
        }

        /* Chessboard Container */
        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            grid-template-rows: repeat(8, 1fr);
            width: 480px;
            height: 480px;
            border-radius: 16px;
            border: 5px solid #34495e;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            position: relative;
        }

        /* Chessboard Squares */
        .square {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 42px;
            font-weight: bold;
            transition: background-color 0.3s ease-in-out;
        }

        /* Light and Dark Squares */
        .square.light {
            background-color: #f3d9b1;
        }

        .square.dark {
            background-color: #b07c5c;
        }

        /* Hover Effect */
        .square:hover {
            background-color: rgba(255, 255, 255, 0.3);
        }

        /* Chess Pieces */
        .piece {
            font-size: 40px;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: grab;
            user-select: none;
            transition: transform 0.2s ease-in-out;
        }

        /* Piece Colors */
        .piece.white {
            color: white;
            text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.8);
        }

        .piece.black {
            color: black;
            text-shadow: 2px 2px 5px rgba(255, 255, 255, 0.5);
        }

        /* Dragging Effect */
        .dragging {
            opacity: 0.7;
        }

        /* Board Rotation for Black Player */
        .flipped {
            transform: rotate(180deg);
        }

        .flipped .piece {
            transform: rotate(180deg);
        }

        /* Title */
        .title {
            font-size: 36px;
            font-weight: bold;
            text-align: center;
            margin-bottom: 20px;
            color: #ecf0f1;
            text-shadow: 2px 2px 10px rgba(255, 255, 255, 0.3);
        }

        /* Button Styles */
        .btn {
            padding: 12px 24px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease-in-out;
            text-transform: uppercase;
            letter-spacing: 1px;
            
        }

        .btn-restart {
            background: #f39c12;
            color: white;
        }

        .btn-restart:hover {
            background: #e67e22;
            transform: scale(1.1);
        }

        .btn-draw {
            background: #3498db;
            color: white;
        }

        .btn-draw:hover {
            background: #2980b9;
            transform: scale(1.1);
        }

        .btn-resign {
            background: #e74c3c;
            color: white;
        }

        .btn-resign:hover {
            background: #c0392b;
            transform: scale(1.1);
        }

        /* Controls Container */
        .controls {
            margin-top: 20px;
            display: flex;
            gap: 15px;
        }

        /* Modern Message Box */
        .game-message {
            position: fixed;
            top: 20px;
            right: -300px;
            padding: 15px 25px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            opacity: 0;
            transition: right 0.5s ease-in-out, opacity 0.5s ease-in-out;
            z-index: 1000;
            color: white;
        }

        /* Show message animation */
        .game-message.visible {
            right: 20px;
            opacity: 1;
        }

        /* Color Variations */
        .message-restart {
            background: #f39c12;
        }

        .message-resign {
            background: #e74c3c;
        }

        .message-draw {
            background: #3498db;
        }

        .message-default {
            background: rgba(30, 30, 30, 0.9);
        }

        /* Overlay for Confirmation */
        .overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: flex; justify-content: center; align-items: center;
        }
        
        .promotion-container {
            background: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
        }
        
        .promotion-btn {
            font-size: 24px;
            margin: 5px;
            width: 50px; height: 50px;
            border: none;
            cursor: pointer;
            background: none;
        }
        
        .promotion-btn:hover {
            transform: scale(1.2);
        }        
        
        /* Confirmation Box */
        .confirmation-box {
            background: #2c3e50;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            width: 300px;
        }

        .confirmation-box p {
            color: #ecf0f1;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        /* Confirmation Buttons */
        .btn-confirm {
            background: #27ae60;
            color: white;
            margin-right: 0.5rem;
            height: 2rem;
            width: 4rem;
            border-radius:1rem;
        }

        .btn-cancel {
            background: #e74c3c;
            color: white;
            height: 2rem;
            width: 4rem;
            border-radius:1rem;
        }
        /* Highlight last move */
        .square.highlight {
            background-color: rgba(255, 255, 0, 0.4) !important;
        }

        /* Scoreboard */
        .scoreboard {
            width: 480px;
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 14px;
        }
        .score-side {
            flex: 1;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid #34495e;
            border-radius: 10px;
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            min-height: 46px;
        }
        .score-side.turn {
            border-color: #f1c40f;
            box-shadow: 0 0 10px rgba(241, 196, 15, 0.35);
        }
        .score-head {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }
        .score-label {
            font-weight: bold;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #ecf0f1;
        }
        .score-lead {
            font-size: 11px;
            color: #2ecc71;
            min-height: 13px;
        }
        .score-points {
            font-size: 24px;
            font-weight: bold;
            color: #f1c40f;
            min-width: 26px;
            text-align: center;
        }
        .captured {
            font-size: 20px;
            line-height: 1;
            display: flex;
            flex-wrap: wrap;
            gap: 1px;
            flex: 1;
        }
        .captured .cap-w {
            color: #ffffff;
            text-shadow: 0 0 2px rgba(0, 0, 0, 0.7);
        }
        .captured .cap-b {
            color: #1c1c1c;
            text-shadow: 0 0 2px rgba(255, 255, 255, 0.45);
        }

        /* Race bar */
        .racebar {
            width: 480px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid #34495e;
            border-radius: 10px;
            padding: 10px 14px;
            margin-top: 14px;
            display: flex;
            flex-direction: column;
            gap: 7px;
        }
        .race-top {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            color: #ecf0f1;
        }
        .race-status {
            font-size: 16px;
            font-weight: bold;
            color: #f1c40f;
            min-height: 20px;
        }
        .cooldown-track {
            height: 7px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 4px;
            overflow: hidden;
        }
        .cooldown-fill {
            height: 100%;
            width: 0%;
            background: #2ecc71;
            transition: width 0.1s linear;
        }
        .chessboard.locked {
            opacity: 0.88;
        }
        .chessboard.locked .piece {
            cursor: not-allowed;
        }
        .race-rules {
            width: 480px;
            font-size: 12px;
            color: #9aa7b3;
            margin-top: 8px;
            text-align: center;
            line-height: 1.5;
        }

    </style>
</head>

<body>
    <div class="flex flex-col items-center">
        <div class="title">♜ Chessmate ♞</div>
        <div id="scoreboard" class="scoreboard">
            <div id="sideWhite" class="score-side">
                <div class="score-head">
                    <span class="score-label">White</span>
                    <span id="whiteLead" class="score-lead"></span>
                </div>
                <span id="whitePoints" class="score-points">0</span>
                <span id="whiteCaptured" class="captured"></span>
            </div>
            <div id="sideBlack" class="score-side">
                <div class="score-head">
                    <span class="score-label">Black</span>
                    <span id="blackLead" class="score-lead"></span>
                </div>
                <span id="blackPoints" class="score-points">0</span>
                <span id="blackCaptured" class="captured"></span>
            </div>
        </div>
        <div id="chessboard" class="chessboard"></div>
        <div class="controls">
            <button id="restartGame" class="btn btn-restart">Restart Game</button>
            <button id="offerDraw" class="btn btn-draw">Offer Draw</button>
            <button id="resignGame" class="btn btn-resign">Resign</button>
        </div>
        <div id="raceBar" class="racebar">
            <div class="race-top">
                <span id="raceRole">—</span>
                <span id="raceCounts">Moves — White 0 · Black 0</span>
            </div>
            <div id="raceStatus" class="race-status">Connecting…</div>
            <div class="cooldown-track"><div id="cooldownBar" class="cooldown-fill"></div></div>
        </div>
        <div class="race-rules">
            Race chess: get up to 3 moves ahead of your opponent. Leading costs time —
            wait 3s at +1, 8s at +2, blocked at +3. White moves first.
        </div>
    </div>

    <!-- External Scripts -->
    <script src="https://cdn.socket.io/4.8.1/socket.io.min.js"
        crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js" crossorigin="anonymous"></script>
    <script src="/js/chess.js?v=2"></script>
</body>

</html>
