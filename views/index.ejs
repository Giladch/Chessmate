<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chessmate</title>
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; height: 100%; }
        body {
            background: radial-gradient(circle at 50% 38%, #242440, #13131d 70%);
            color: #fff;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            user-select: none;
        }

        /* full-window pannable world */
        #viewport { position: fixed; inset: 0; overflow: hidden; cursor: grab; touch-action: none; }
        #viewport.panning { cursor: grabbing; }
        #world { position: absolute; left: 0; top: 0; transform-origin: 0 0; }

        .square {
            position: absolute;
            width: 96px; height: 96px;
            display: flex; align-items: center; justify-content: center;
            line-height: 1;
        }
        .square.light { background: #f3d9b1; }
        .square.dark { background: #b07c5c; }
        .square.zone::after {
            content: ""; position: absolute; inset: 0;
            background: rgba(243, 156, 18, 0.22); pointer-events: none;
        }
        .square.highlight { box-shadow: inset 0 0 0 4px rgba(255, 255, 0, 0.5); }
        .square.king-flash { animation: kingflash 0.4s ease-in-out 2; z-index: 5; }
        @keyframes kingflash {
            0% { box-shadow: inset 0 0 0 0 rgba(231, 76, 60, 0); }
            50% { box-shadow: inset 0 0 0 96px rgba(231, 76, 60, 0.78); }
            100% { box-shadow: inset 0 0 0 0 rgba(231, 76, 60, 0); }
        }

        /* buildable candidate: grid on/off indication, stronger + animated */
        .square.buildable {
            background: transparent;
            border: 2px dashed rgba(46, 204, 113, 0.35);
            border-radius: 10px;
            cursor: pointer;
            transition: background .15s ease, border-color .15s ease, box-shadow .15s ease, transform .12s ease;
        }
        .square.buildable:hover {
            background: rgba(46, 204, 113, 0.32);
            border-color: #2ecc71;
            box-shadow: inset 0 0 0 3px rgba(46, 204, 113, 0.65), 0 0 16px rgba(46, 204, 113, 0.45);
            transform: scale(1.05);
        }
        .square.buildable.bad { border-color: rgba(231, 76, 60, 0.4); }
        .square.buildable.bad:hover {
            background: rgba(231, 76, 60, 0.26);
            border-color: #e74c3c;
            box-shadow: inset 0 0 0 3px rgba(231, 76, 60, 0.6);
        }

        .piece {
            width: 100%; height: 100%;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center bottom;
            transform-origin: center bottom;
            filter: drop-shadow(1px 2px 2px rgba(0, 0, 0, 0.45));
            touch-action: none;
        }
        /* landing indicator while dragging a piece */
        .square.drop-ok {
            box-shadow: inset 0 0 0 4px rgba(46, 204, 113, 0.9), 0 0 18px rgba(46, 204, 113, 0.5);
            z-index: 3;
        }
        .drag-ghost {
            position: fixed;
            pointer-events: none;
            z-index: 2000;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center bottom;
            filter: drop-shadow(2px 4px 4px rgba(0, 0, 0, 0.55));
            opacity: 0.92;
        }

        /* HUD chips — single design line: rounded, shadow, translucent, opaque on hover */
        .chip {
            z-index: 50;
            background: #ffffff; color: #111;
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
            opacity: 0.45;
            transition: opacity .18s ease, transform .1s ease;
            display: flex; align-items: center; justify-content: center;
        }
        .chip:hover { opacity: 1; }
        .credit-chip { min-width: 54px; height: 54px; padding: 0 14px; font-size: 26px; font-weight: bold; }
        #myCredit { position: fixed; left: 18px; bottom: 18px; }
        #enemyCredit { position: fixed; right: 18px; top: 18px; }
        #controls { position: fixed; right: 18px; bottom: 18px; z-index: 50; display: flex; gap: 8px; }
        .icon-chip { width: 40px; height: 40px; font-size: 20px; font-weight: bold; cursor: pointer; border: none; font-family: inherit; }
        .icon-chip:active { transform: scale(0.92); }

        /* turn edges */
        .edge { position: fixed; left: 0; right: 0; height: 90px; pointer-events: none; z-index: 40; opacity: 0; }
        #edgeTop { top: 0; }
        #edgeBottom { bottom: 0; }
        .edge.active { animation: edgepulse 1.1s ease-in-out infinite; }
        #edgeTop.c-white.active { box-shadow: inset 0 70px 60px -40px rgba(255, 255, 255, 0.7); }
        #edgeTop.c-black.active { box-shadow: inset 0 70px 60px -40px rgba(0, 0, 0, 0.92); }
        #edgeBottom.c-white.active { box-shadow: inset 0 -70px 60px -40px rgba(255, 255, 255, 0.7); }
        #edgeBottom.c-black.active { box-shadow: inset 0 -70px 60px -40px rgba(0, 0, 0, 0.92); }
        @keyframes edgepulse { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }

        /* overlays */
        .overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .promotion-container, .confirmation-box { background: #2c3e50; padding: 20px; border-radius: 12px; text-align: center; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5); }
        .promotion-container p, .confirmation-box p { color: #ecf0f1; font-size: 18px; font-weight: bold; margin: 0 0 14px; }
        .promotion-btn { font-size: 30px; width: 54px; height: 54px; margin: 4px; border: none; background: #34495e; color: #fff; border-radius: 10px; cursor: pointer; }
        .promotion-btn:hover { background: #3d5a73; }
        .btn-confirm, .btn-cancel { height: 36px; min-width: 72px; border: none; border-radius: 18px; color: #fff; font-weight: bold; cursor: pointer; margin: 0 6px; }
        .btn-confirm { background: #27ae60; } .btn-cancel { background: #e74c3c; }
        .game-message { position: fixed; top: 18px; left: 50%; transform: translateX(-50%); padding: 12px 22px; border-radius: 10px; font-weight: bold; color: #fff; z-index: 1200; opacity: 0; transition: opacity .4s; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.4); }
        .game-message.visible { opacity: 1; }
        .message-default { background: rgba(30, 30, 30, 0.92); } .message-error { background: #c0392b; } .message-restart { background: #e67e22; } .message-draw { background: #2980b9; } .message-resign { background: #c0392b; }

        /* buy radial menu */
        .radial-capture { position: fixed; inset: 0; z-index: 1100; }
        .radial-menu { position: fixed; transform: translate(-50%, -50%); z-index: 1101; }
        .radial-option { position: absolute; transform: translate(-50%, -50%); width: 96px; height: 96px; border-radius: 50%; background: #2c3e50; border: 3px solid #34495e; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: transform .1s, border-color .1s; box-shadow: 0 6px 16px rgba(0, 0, 0, 0.55); }
        .radial-option .ro-glyph { font-size: 42px; line-height: 1; }
        .radial-option .ro-glyph.ro-w { color: #fff; text-shadow: 0 0 2px #000; }
        .radial-option .ro-glyph.ro-b { color: #141414; text-shadow: 0 0 2px #fff; }
        .radial-option .ro-cost { font-size: 16px; color: #f1c40f; }
        .radial-option.hover { border-color: #2ecc71; transform: translate(-50%, -50%) scale(1.18); }
        .radial-option.disabled { opacity: 0.4; cursor: not-allowed; }
        .radial-option.disabled.hover { border-color: #e74c3c; }

        /* move-history panel (top-left) — same chip language: translucent, opaque on hover */
        #movePanel {
            position: fixed; left: 18px; top: 18px; z-index: 60;
            width: 210px; max-width: 46vw;
            background: #ffffff; color: #111;
            border-radius: 14px; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
            opacity: 0.5; transition: opacity .18s ease;
            font-size: 13px; overflow: hidden;
        }
        #movePanel:hover, #movePanel.reviewing { opacity: 1; }
        #moveHead {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 12px; font-weight: bold; cursor: pointer;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }
        #moveHead .mh-count { font-weight: normal; color: #666; font-size: 12px; }
        #moveList { max-height: 44vh; overflow-y: auto; padding: 4px 0; }
        #movePanel.collapsed #moveList, #movePanel.collapsed #moveNav { display: none; }
        .move-row {
            display: flex; align-items: center; gap: 8px;
            padding: 3px 12px; cursor: pointer; white-space: nowrap;
        }
        .move-row:hover { background: rgba(0, 0, 0, 0.06); }
        .move-row.active { background: rgba(46, 134, 222, 0.18); font-weight: bold; }
        .move-row .mr-dot {
            width: 11px; height: 11px; border-radius: 50%; flex: 0 0 auto;
            border: 1px solid rgba(0, 0, 0, 0.35);
        }
        .move-row .mr-dot.w { background: #fafafa; }
        .move-row .mr-dot.b { background: #222; }
        .move-row .mr-kind { color: #b06a14; } /* build/buy entries tinted */
        .move-empty { padding: 8px 12px; color: #888; font-style: italic; }
        #moveNav {
            display: flex; align-items: center; gap: 4px;
            padding: 6px 10px; border-top: 1px solid rgba(0, 0, 0, 0.08);
        }
        #moveNav button {
            flex: 1; height: 26px; border: none; background: rgba(0, 0, 0, 0.06);
            border-radius: 7px; cursor: pointer; font-size: 13px; color: #222; font-family: inherit;
        }
        #moveNav button:hover { background: rgba(0, 0, 0, 0.12); }
        #moveNav button:active { transform: scale(0.94); }
        #moveStatus {
            flex: 1.4; text-align: center; font-size: 11px; font-weight: bold;
            border-radius: 7px; padding: 4px 0;
        }
        #moveStatus.live { color: #1c8a4a; background: rgba(39, 174, 96, 0.14); }
        #moveStatus.review { color: #b06a14; background: rgba(230, 126, 34, 0.16); cursor: pointer; }

        /* persistent "reviewing" banner */
        #reviewBanner {
            position: fixed; top: 18px; left: 50%; transform: translateX(-50%);
            z-index: 70; display: none; align-items: center; gap: 10px;
            padding: 8px 16px; border-radius: 10px; font-weight: bold; font-size: 13px;
            background: #e67e22; color: #fff; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.4); cursor: pointer;
        }
        #reviewBanner.show { display: flex; }
    </style>
</head>

<body>
    <div id="viewport"><div id="world"></div></div>
    <div id="edgeTop" class="edge"></div>
    <div id="edgeBottom" class="edge"></div>

    <div id="movePanel">
        <div id="moveHead"><span>Moves <span class="mh-count" id="moveCount"></span></span><span id="moveChevron">▾</span></div>
        <div id="moveList"></div>
        <div id="moveNav">
            <button id="navFirst" title="First move">⏮</button>
            <button id="navPrev" title="Previous (←)">◀</button>
            <span id="moveStatus" class="live">LIVE</span>
            <button id="navNext" title="Next (→)">▶</button>
            <button id="navLast" title="Back to live (End)">⏭</button>
        </div>
    </div>
    <div id="reviewBanner"><span id="reviewBannerText"></span><span>· back to live ⏭</span></div>
    <div id="enemyCredit" class="chip credit-chip">0</div>
    <div id="myCredit" class="chip credit-chip">0</div>
    <div id="controls">
        <button id="restartGame" class="chip icon-chip" title="Restart game">&#x21bb;</button>
        <button id="offerDraw" class="chip icon-chip" title="Offer draw">&#xbd;</button>
        <button id="resignGame" class="chip icon-chip" title="Resign">&#x2691;</button>
        <button id="addAI" class="chip icon-chip" title="Play vs computer" style="font-size:13px;">AI</button>
    </div>

    <script src="https://cdn.socket.io/4.8.1/socket.io.min.js" crossorigin="anonymous"></script>
    <script src="/js/chess.js?v=23"></script>
</body>

</html>
